# ─── Kyma AI API ────────────────────────────────────────────────────────────
# Kyma API endpoint (Anthropic-compatible)
KYMA_API_KEY=
KYMA_BASE_URL=https://kymaapi.com/v1

# ─── HuggingFace (Qwen3.5-9B via Inference API) ─────────────────────────────
# Get your token at: https://huggingface.co/settings/tokens
# Free tier: 3 requests/min for inference
HF_TOKEN=

# ─── Tavily ─────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Database ──────────────────────────────────────────────────────────────
# Database URL — different for local vs Docker:
#   Local dev:    localhost:5434  (connects to docker postgres on port 5434)
#   Docker:       postgres:5432  (Docker internal network)
# Set via environment or update before running docker compose
# DATABASE_URL is read from the shell environment in Docker
POSTGRES_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://:ar_redis_2026@localhost:6380

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
